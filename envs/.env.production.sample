# These are NOT read automatically from this file in production.
# Set each of these as real Environment Variables inside the Runflare
# service panel (Service > Settings > Environment Variables).
# This file just documents what to set and never contains real secrets.

SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-service.runflare.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-service.runflare.app,https://yourdomain.com
TIME_ZONE=Asia/Tehran

# Database - use the connection details Runflare gives you
# for the Postgres database service you create.
PGDB_NAME=your-db-name
PGDB_USER=your-db-user
PGDB_PASSWORD=your-db-password
PGDB_HOST=your-db-host-from-runflare
PGDB_PORT=5432

# Email (optional, defaults to console backend if left unset)
EMAIL_HOST=
EMAIL_USE_TLS=True
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Runflare injects a PORT env var for the container to listen on;
# entrypoint.sh already reads it automatically, no need to set it yourself.
